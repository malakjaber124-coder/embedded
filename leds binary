void main() {
    unsigned int i = 0;

    // Configure GPIOA Pins 0, 1, 2, and 3 as Output for the Binary LEDs
    GPIO_Config(&GPIOA_BASE, 
                _GPIO_PINMASK_0 | _GPIO_PINMASK_1 | _GPIO_PINMASK_2 | _GPIO_PINMASK_3, 
                _GPIO_CFG_MODE_OUTPUT | _GPIO_CFG_SPEED_MAX | _GPIO_CFG_OTYPE_PP);

    // Configure GPIOB Pin 0 as Digital Input for the IR Sensor
    GPIO_Digital_Input(&GPIOB_BASE, _GPIO_PINMASK_0);

    // Initialize LEDs to OFF
    GPIOA_ODR = 0;

    for( ; ; ) // Infinite Super-Loop
    {
        // Check IR Sensor: If sensor is triggered (assuming active high/1)
        if (GPIOB_IDR.B0 == 1) 
        {
            // Output the current value of 'i' to the LEDs in binary
            GPIOA_ODR = i;
            
            Delay_ms(1000); // Wait 1 second
            
            i++; // Increment counter
            
            // Reset counter after 15 (4 bits: 0 to 15)
            if (i >= 16) {
                i = 0;
            }
        }
        else 
        {
            // Optional: What happens if NO traffic is detected?
            // For now, we clear the LEDs and wait
            GPIOA_ODR = 0;
            i = 0; // Reset count or keep it? Keeping it 0 for a fresh start.
        }
    }
}
